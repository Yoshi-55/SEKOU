<!-- Hero Section -->
<div class="text-center py-16 px-6">
  <h1 class="text-4xl font-bold mb-4 text-gray-900">
    職人と職人をつなぐ
  </h1>
  <p class="text-lg mb-10 text-gray-600">
    カーラッピング・フリート施工の案件を簡単に掲載・応募
  </p>
  <div class="flex flex-col gap-3 items-center max-w-md mx-auto">
    <% if user_signed_in? %>
      <%= link_to "案件を掲載する", new_job_path, class: "w-full bg-blue-600 text-white px-8 py-3 rounded-lg font-medium hover:bg-blue-700 transition text-center" %>
      <%= link_to "案件を探す", jobs_path, class: "w-full border border-gray-300 text-gray-700 px-8 py-3 rounded-lg font-medium hover:bg-gray-50 transition text-center" %>
    <% else %>
      <%= link_to "今すぐ始める", new_user_registration_path, class: "w-full bg-blue-600 text-white px-8 py-3 rounded-lg font-medium hover:bg-blue-700 transition text-center" %>
      <%= link_to "案件を探す", jobs_path, class: "w-full border border-gray-300 text-gray-700 px-8 py-3 rounded-lg font-medium hover:bg-gray-50 transition text-center" %>
    <% end %>
  </div>
</div>

<!-- Features Section -->
<div class="max-w-4xl mx-auto px-6 py-12">
  <div class="grid md:grid-cols-2 gap-8">
    <div class="text-center p-6">
      <div class="text-4xl mb-4">👥</div>
      <h3 class="text-xl font-bold mb-2">グループ限定</h3>
      <p class="text-gray-600">
        グループ内のクローズドな環境
      </p>
    </div>

    <div class="text-center p-6">
      <div class="text-4xl mb-4">🔒</div>
      <h3 class="text-xl font-bold mb-2">安心・安全</h3>
      <p class="text-gray-600">
        詳細住所は承認後に表示
      </p>
    </div>
  </div>
</div>

<!-- How to Use Section -->
<div class="max-w-2xl mx-auto px-6 py-12 border-t border-gray-200">
  <h2 class="text-2xl font-bold mb-8 text-center">使い方</h2>
  <div class="space-y-6">
    <div class="flex gap-4 items-start">
      <div class="shrink-0 w-8 h-8 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold text-sm">
        1
      </div>
      <div>
        <h3 class="font-bold mb-1">グループを作成・参加</h3>
        <p class="text-gray-600 text-sm">グループを作成</p>
      </div>
    </div>

    <div class="flex gap-4 items-start">
      <div class="shrink-0 w-8 h-8 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold text-sm">
        2
      </div>
      <div>
        <h3 class="font-bold mb-1">案件を掲載</h3>
        <p class="text-gray-600 text-sm">施工案件をグループに公開</p>
      </div>
    </div>

    <div class="flex gap-4 items-start">
      <div class="shrink-0 w-8 h-8 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold text-sm">
        3
      </div>
      <div>
        <h3 class="font-bold mb-1">応募・マッチング</h3>
        <p class="text-gray-600 text-sm">応募を承認してマッチング成立</p>
      </div>
    </div>

    <div class="flex gap-4 items-start">
      <div class="shrink-0 w-8 h-8 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold text-sm">
        4
      </div>
      <div>
        <h3 class="font-bold mb-1">施工・完了</h3>
        <p class="text-gray-600 text-sm">施工を行い案件を完了</p>
      </div>
    </div>
  </div>

  <div class="text-center mt-10">
    <% if user_signed_in? %>
      <%= link_to "グループを作成する", new_group_path, class: "bg-blue-600 hover:bg-blue-700 text-white px-8 py-3 rounded-lg font-medium inline-block transition" %>
    <% else %>
      <%= link_to "今すぐ始める", new_user_registration_path, class: "bg-blue-600 hover:bg-blue-700 text-white px-8 py-3 rounded-lg font-medium inline-block transition" %>
    <% end %>
  </div>
</div>
